# Frontend (Vite)
# Copy to .env and adjust values.

VITE_API_BASE_URL=http://localhost:8000/api

# Mixpanel project token (Project Settings > Access Keys in Mixpanel).
# Leave unset to disable tracking (analytics.ts no-ops without it).
VITE_MIXPANEL_TOKEN=

# Payment providers — PUBLIC keys only. Never put secret keys here.
VITE_PAYSTACK_PUBLIC_KEY=
VITE_FLUTTERWAVE_PUBLIC_KEY=

