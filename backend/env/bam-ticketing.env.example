# Application
APP_NAME="EventIQ"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Payment Gateway Selection
# e.g. paystack, flutterwave
PAYMENT_GATEWAY=paystack
PAYMENT_GATEWAY_SECRET_KEY=

# Payout Orchestration
PAYOUT_HOLD_DAYS=3
PAYOUT_MAX_RETRIES=3
AUDIT_LOG_ENABLED=true

# Paystack
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_PAYMENT_URL=https://api.paystack.co
PAYSTACK_MERCHANT_EMAIL=
PAYSTACK_CALLBACK_URL=/api/payments/paystack/callback
PAYSTACK_WEBHOOK_URL=/api/payments/paystack/webhook

# Flutterwave
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_PAYMENT_URL=https://api.flutterwave.com/v3
FLUTTERWAVE_WEBHOOK_SECRET_HASH=
FLUTTERWAVE_CALLBACK_URL=/api/payments/flutterwave/callback
FLUTTERWAVE_WEBHOOK_URL=/api/payments/flutterwave/webhook

