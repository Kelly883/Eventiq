APP_NAME=EventIQ
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC
APP_LOCALE=en

DB_CONNECTION=sqlite
DB_DATABASE=

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database
FILESYSTEM_DISK=local

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Restored - dropped in an earlier restructuring push. Needed for
# TicketDeliveryService::sendViaEmail() and EmailTemplateService::sendTest()
# (both use Mail::), and for password-reset emails via config/auth.php.
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=hello@eventiq.example
MAIL_FROM_NAME="${APP_NAME}"

# Frontend origin(s) allowed to call this API (comma-separated).
CORS_ALLOWED_ORIGINS=http://localhost:5173
SANCTUM_STATEFUL_DOMAINS=localhost:5173

VITE_MIXPANEL_TOKEN=
VITE_API_BASE_URL=http://localhost:8000

# Paystack
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=
PAYSTACK_PAYMENT_URL=https://api.paystack.co

# Flutterwave
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_PAYMENT_URL=https://api.flutterwave.com/v3
# Separate "Secret Hash" from the Flutterwave dashboard, used only for
# webhook signature verification - not the same as the API secret key.
FLUTTERWAVE_WEBHOOK_SECRET_HASH=

APP_CURRENCY=NGN

VITE_PAYSTACK_PUBLIC_KEY=
VITE_FLUTTERWAVE_PUBLIC_KEY=

# Sift Science fraud detection
SIFT_API_KEY=
SIFT_ACCOUNT_ID=
SIFT_API_BASE_URL=https://api.sift.com/v205

# Fraud risk thresholds (overridable per environment)
HIGH_RISK_THRESHOLD=75
MEDIUM_RISK_THRESHOLD=31
VELOCITY_LIMIT_24H=10
VELOCITY_LIMIT_1H=3
CARD_TESTING_THRESHOLD=5
MAX_TICKETS_PER_TRANSACTION=10
MAX_TRANSACTIONS_PER_DEVICE=5
MAX_TRANSACTIONS_PER_IP=10

# Ticket delivery (email + SMS). NOT "bam-ticketing" - that package
# doesn't exist for PHP/Composer. See config/ticket-delivery.php.
TICKET_DELIVERY_EMAIL_FROM=
TICKET_DELIVERY_EMAIL_FROM_NAME=EventIQ
TICKET_DELIVERY_SMS_FROM=
TICKET_DELIVERY_WEBHOOK_SECRET=
TERMII_API_KEY=
TERMII_BASE_URL=https://api.ng.termii.com
TERMII_CHANNEL=dnd

# MJML email rendering. MJML is a Node.js package with no PHP port - this
# server needs Node.js installed for it to work. See config/mjml.php and
# backend/node-tools/mjml/ (run `npm install` there once, separately from
# the PHP composer install).
MJML_ENABLED=true
MJML_NODE_BINARY=node

# Firebase Admin SDK (push notifications). Download the service account
# JSON from Firebase Console > Project Settings > Service Accounts, save
# it at the path below (gitignored), never commit it.
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS=storage/app/firebase-credentials.json

# Payouts (refunds/settlements) - use the same Paystack/Flutterwave
# gateways above via PaymentGatewayService, not a separate Stripe/PayPal
# integration. See PAYSTACK_*/FLUTTERWAVE_* vars earlier in this file.
PAYOUT_HOLD_DAYS=3
PAYOUT_MAX_RETRIES=3
AUDIT_LOG_ENABLED=true

# Audit trail (config/logging.php's 'audit' channel + audit_logs table).
# LOG_DAILY_DAYS controls file rotation (disk space);
# AUDIT_LOG_RETENTION_DAYS is a separate concern - how long DB rows are
# kept for compliance purposes (365 = 1yr, 2555 = 7yr are common
# regulatory minimums, adjust to your actual requirements).
LOG_DAILY_DAYS=14
AUDIT_LOG_RETENTION_DAYS=365
COMPLIANCE_REPORT_QUEUE=compliance
