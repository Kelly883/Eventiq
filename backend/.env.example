# Backend (Laravel)
# Copy to .env and adjust values.

APP_NAME="EventIQ"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8000

# Generate with: php artisan key:generate
APP_KEY=

# Database
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=eventiq
DB_USERNAME=root
DB_PASSWORD=

# Mail (password reset)
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="EventIQ"

# Development: write emails to logs
MAIL_DRIVER=log

# Sanctum stateful domains (React dev server)
SANCTUM_STATEFUL_DOMAINS=localhost:5173

# Filesystem
FILESYSTEM_DISK=local

# If using S3/object storage, add these:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=
# AWS_BUCKET=

