APP_NAME=EventIQ
APP_ENV=testing
APP_KEY=base64:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=UTC

DB_CONNECTION=sqlite
DB_DATABASE=:memory:

SESSION_DRIVER=array
CACHE_STORE=array
QUEUE_CONNECTION=sync

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_LEVEL=debug

MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@eventiq.example
MAIL_FROM_NAME=EventIQ

AUDIT_LOG_ENABLED=true
AUDIT_LOG_RETENTION_DAYS=365
