# Frontend Public Keys
VITE_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxx
VITE_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxxxxxxxxxx
VITE_QR_API_URL=http://localhost:8000/api/venue/check-in/qr

# Ticket delivery (email + SMS). NOT "bam-ticketing" - that package
# doesn't exist for PHP/Composer.
TICKET_DELIVERY_EMAIL_FROM=
TICKET_DELIVERY_EMAIL_FROM_NAME=EventIQ
TICKET_DELIVERY_SMS_FROM=
TICKET_DELIVERY_WEBHOOK_SECRET=
TERMII_API_KEY=
TERMII_BASE_URL=https://api.ng.termii.com
TERMII_CHANNEL=dnd

# Fraud Detection (Sift, Paystack, Flutterwave)
SIFT_API_KEY=
SIFT_ACCOUNT_ID=
SIFT_API_BASE_URL=https://api.sift.com/v205

# Fraud Risk Thresholds
HIGH_RISK_THRESHOLD=75
MEDIUM_RISK_THRESHOLD=31
VELOCITY_LIMIT_24H=10
VELOCITY_LIMIT_1H=3
CARD_TESTING_THRESHOLD=5
MAX_TICKETS_PER_TRANSACTION=10
MAX_TRANSACTIONS_PER_DEVICE=5
MAX_TRANSACTIONS_PER_IP=10

# Firebase (push notifications). Frontend values are public client
# identifiers (safe to expose) from Firebase Console > Project Settings >
# General > Your apps > Web app. Backend FIREBASE_CREDENTIALS points to a
# service account JSON file - never commit the real file.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
FIREBASE_PROJECT_ID=
FIREBASE_CREDENTIALS=storage/app/firebase-credentials.json
